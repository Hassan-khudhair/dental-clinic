{
  "version": 2,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile && cd apps/api && npx prisma generate",
  "buildCommand": "nest build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
